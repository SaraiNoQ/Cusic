{
  "name": "music-ai-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "prepare": "husky",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.0",
    "prisma": "^6.7.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.28.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,yaml,yml,md,css}": [
      "prettier --write"
    ]
  }
}
