NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/music_app
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000

SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-me@163.com
SMTP_PASSWORD=replace-me
SMTP_FROM="Cusic <replace-me@163.com>"

API_PORT=3001
WEB_PORT=3000
WORKER_LOG_LEVEL=info
API_CORS_ORIGINS=http://localhost:3000,https://web.sarainoq.cn

NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
# Production example:
# NEXT_PUBLIC_API_BASE_URL=https://api.sarainoq.cn/api/v1
NEXT_PUBLIC_APP_NAME=Music AI App

LLM_PROVIDER=qwen
LLM_API_KEY=replace-me
