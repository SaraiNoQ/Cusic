NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/music_app
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=2592000

SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=replace-me@163.com
SMTP_PASSWORD=replace-me
SMTP_FROM="Cusic <replace-me@163.com>"

API_PORT=3001
WEB_PORT=3000
WORKER_LOG_LEVEL=info
IMPORTS_QUEUE_NAME=music-ai-imports
WORKER_IMPORTS_CONCURRENCY=1
API_CORS_ORIGINS=http://localhost:3000,https://web.sarainoq.cn
API_INTERNAL_URL=http://api:3001

NEXT_PUBLIC_API_BASE_URL=/api/v1
# 使用 Next.js rewrites 代理 API 请求，避免跨域问题。
# 生产部署时 API_INTERNAL_URL 设为 Docker 内部地址 (http://api:3001)；
# 本地开发时默认为 http://localhost:3001。
NEXT_PUBLIC_APP_NAME=Music AI App

LLM_PROVIDER=deepseek
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_REQUEST_TIMEOUT_MS=15000
LLM_ENABLED=false

JAMENDO_CLIENT_ID=replace-me

# Bing Web Search (used by Knowledge module for real-time web queries)
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Voice Provider (mimo | aliyun | stub)
VOICE_PROVIDER=mimo
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_ASR_APP_KEY=
ALIYUN_TTS_APP_KEY=
